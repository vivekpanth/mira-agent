# Copy to .env.local. NEVER commit real keys. Only app/api/* (server) reads these.
# MIRA runs on a PRIVATE, ON-DEVICE AI stack — no Bedrock, no Polly, no cloud LLM.

# ---- Dialogue LLM (local: LM Studio or Ollama) ---------------------------
# LLM_PROVIDER: auto (detect from base url) | lmstudio | ollama | local (= ollama)
LLM_PROVIDER=auto
LMSTUDIO_ENABLED=true
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3-8b
LMSTUDIO_TEMPERATURE=0.75
LMSTUDIO_MAX_TOKENS=400
LMSTUDIO_TIMEOUT_MS=45000

# Ollama instead of LM Studio:
# LLM_PROVIDER=ollama
# LMSTUDIO_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_MODEL=gemma4:e4b

# ---- Client voice (local neural TTS) -------------------------------------
# TTS_ENGINE: auto | kokoro-docker | kokoro | piper | macos | browser
# Kokoro Docker is started by: npm run tts:up
TTS_ENGINE=auto
KOKORO_BASE_URL=http://localhost:8880/v1
# Optional Piper HTTP server, e.g. http://localhost:5000
# PIPER_BASE_URL=http://localhost:5000

# ---- Eye contact (optional, Amazon Rekognition) --------------------------
# The ONLY optional cloud call. Gated by USE_MOCKS: real DetectFaces when
# false, deterministic ~75% mock when true (keeps the demo cost-free).
# Rekognition reuses the AWS_* credentials below via the default SDK chain.
USE_MOCKS=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Webcam sample interval (client-side, hence NEXT_PUBLIC_). Free tier = 5,000 img/mo.
NEXT_PUBLIC_VISION_SAMPLE_MS=3500

# ---- notes ---------------------------------------------------------------
# - With USE_MOCKS=true the whole app runs locally — no AWS account needed.
# - Set an AWS Budgets alert at $1 before flipping USE_MOCKS=false.
# - The downloaded recording captures the 3D SCENE canvas (avatar + room + the
#   student's in-scene monitor) + mic audio — not the raw webcam.
