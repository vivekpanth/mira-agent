# Copy to .env.local. NEVER commit real keys. Only app/api/* (server) reads these.

# ---- master switch -------------------------------------------------------
# true  = use deterministic mocks for ALL services (build + demo on this)
# false = call real AWS. Flip per-service only once each is verified working.
USE_MOCKS=true

# ---- AWS (only needed when USE_MOCKS=false) ------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- LLM provider --------------------------------------------------------
# Where persona/dialogue/report prose comes from:
#   local  = on-device Ollama (quota-proof; needs `ollama serve` + the model pulled)
#   bedrock (default) = Amazon Bedrock / Claude
# Polly and the other AWS services are independent of this switch.
LLM_PROVIDER=bedrock
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434

# Bedrock model id (use a small/cheap model for dialogue; covered by $200 new-account credit)
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# Amazon Polly default voice (neural). e.g. Joanna / Matthew / Amy
POLLY_VOICE_ID=Joanna

# S3 bucket for recordings + report json (optional; download-only works without it)
S3_BUCKET=

# ---- Eye contact (Amazon Rekognition) ------------------------------------
# Rekognition needs NO extra keys — it reuses AWS_* above and is gated by
# USE_MOCKS (real DetectFaces when false, deterministic ~75% mock when true).
# The rehearsal screen samples the webcam every NEXT_PUBLIC_VISION_SAMPLE_MS
# (client-side, hence the NEXT_PUBLIC_ prefix) and aggregates eyeContactPct
# into the report. Free tier = 5,000 images/mo; 3500ms is plenty of headroom.
NEXT_PUBLIC_VISION_SAMPLE_MS=3500

# ---- notes ---------------------------------------------------------------
# - Set an AWS Budgets alert at $1 before flipping USE_MOCKS=false.
# - Transcribe free tier = 60 min/mo; prefer on-device Web Speech in the browser for STT.
# - Comprehend is optional Tier-3; keep mocked unless Tier 1-2 is demo-stable.
# - The downloaded recording captures the 3D SCENE canvas (avatar + room + the
#   student's in-scene monitor) + mic audio — not the raw webcam.
